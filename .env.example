# =============================
# MUBIS Frontend - Environment
# =============================

# Local backend API
VITE_API_URL=http://localhost:3000/api

# Socket.IO backend origin. In production this is usually the API host without /api.
VITE_WS_URL=http://localhost:3000

# Default tenant used by demo login flows
VITE_DEFAULT_TENANT_SLUG=mubis-demo

# Production example:
# VITE_API_URL=https://api.your-domain.com/api
# VITE_WS_URL=https://api.your-domain.com
